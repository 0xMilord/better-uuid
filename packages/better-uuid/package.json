{
  "name": "better-uuid",
  "version": "0.0.4",
  "description": "Structured, inspectable identifiers — not opaque random strings",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./core": {
      "import": {
        "types": "./dist/core.d.ts",
        "default": "./dist/core.js"
      },
      "require": {
        "types": "./dist/core.d.cts",
        "default": "./dist/core.cjs"
      }
    },
    "./compat/uuid": {
      "import": {
        "types": "./dist/compat/uuid.d.ts",
        "default": "./dist/compat/uuid.js"
      },
      "require": {
        "types": "./dist/compat/uuid.d.cts",
        "default": "./dist/compat/uuid.cjs"
      }
    },
    "./compat/nanoid": {
      "import": {
        "types": "./dist/compat/nanoid.d.ts",
        "default": "./dist/compat/nanoid.js"
      },
      "require": {
        "types": "./dist/compat/nanoid.d.cts",
        "default": "./dist/compat/nanoid.cjs"
      }
    },
    "./compat": {
      "import": {
        "types": "./dist/compat/index.d.ts",
        "default": "./dist/compat/index.js"
      },
      "require": {
        "types": "./dist/compat/index.d.cts",
        "default": "./dist/compat/index.cjs"
      }
    },
    "./patch": {
      "import": {
        "types": "./dist/patch.d.ts",
        "default": "./dist/patch.js"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "wasm"
  ],
  "scripts": {
    "build": "pnpm build:wasm && pnpm build:ts",
    "build:wasm": "wasm-pack build ../../crates/better_uuid_wasm --target bundler --dev --out-dir ../better-uuid/wasm",
    "build:ts": "tsc --build tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --reporter=verbose",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check src/"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^25.5.2",
    "@vitest/coverage-v8": "^4.1.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/better-uuid/better-uuid",
    "directory": "packages/better-uuid"
  },
  "keywords": [
    "uuid",
    "ulid",
    "nanoid",
    "snowflake",
    "id-generation",
    "wasm",
    "typescript"
  ]
}
